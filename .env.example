# ━━ CiviquePro - Environment Variables ━━
# Copy this file to .env and fill in the values

# Database (required)
# — Local development (SQLite):
DATABASE_URL=file:./dev.db
# — Production (Neon PostgreSQL):
# DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-XXXX-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require

# Authentication (required — MUST be changed in production)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional - mock mode used if not set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
