# ━━ CiviquePro - Environment Variables ━━
# Copy this file to `.env` and fill in the values.
# Generate a fresh NEXTAUTH_SECRET with:  openssl rand -base64 32

# ── Database (required) ──
# Local development (Neon free tier recommended even for dev):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
# Example Neon: postgresql://neondb_owner:npg_xxxx@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Authentication (required) ──
# Generate a strong random secret — never commit the real value
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
# Public URL of the deployment (Render auto-fills via fromService.hosturl)
NEXTAUTH_URL=http://localhost:3000

# ── OAuth Providers (optional) ──
# Leave commented to use credentials-only auth (email + password).
# If unset, mock providers are enabled in development for testing.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ── Rate Limiting (optional, production recommended) ──
# Upstash Redis for distributed rate limiting across instances.
# If unset, falls back to in-memory rate limiter (single-instance only).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
