// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth - NextAuth.js Models
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials auth (hashed with bcrypt)
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  posts    Post[]
  results  QuizResult[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ============================================================
// Quiz Results - Progress Tracking
// ============================================================

model QuizResult {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  quizType      String   // "qcm" | "examen-blanc" | "theme"
  themeId       String?  // For theme-specific quizzes
  serieId       String?  // For specific series
  
  totalQuestions Int
  correctAnswers Int
  score          Float   // Percentage (0-100)
  passed         Boolean
  
  timeUsed      Int      // Seconds used
  answers       String   // JSON string of answers
  
  completedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([quizType])
}

// ============================================================
// Veille IA - Surveillance des évolutions juridiques
// ============================================================

model LegalUpdate {
  id          String   @id @default(cuid())
  title       String
  description String
  source      String   // URL ou nom de la source
  category    String   // "loi" | "circulaire" | "decret" | "gouvernement" | "jurisprudence" | "institutionnel"
  status      String   @default("detected") // "detected" | "analyzed" | "applied" | "ignored"
  impact      String   @default("medium")   // "low" | "medium" | "high" | "critical"
  relevance   String   @default("pending")  // "pending" | "relevant" | "irrelevant"
  aiAnalysis  String?  // Analyse IA du changement
  searchDate  DateTime @default(now())
  analyzedAt  DateTime?
  appliedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  suggestions QuestionSuggestion[]

  @@index([status])
  @@index([category])
  @@index([impact])
  @@index([createdAt])
}

model QuestionSuggestion {
  id            String   @id @default(cuid())
  legalUpdateId String
  legalUpdate   LegalUpdate @relation(fields: [legalUpdateId], references: [id], onDelete: Cascade)

  action        String   // "add" | "modify" | "remove"
  themeId       String   // ID du thème concerné
  questionId    String?  // ID de la question existante (si modification/suppression)
  
  originalData  String?  // JSON de la question originale (si modification)
  suggestedData String   // JSON de la nouvelle question suggérée
  
  reason        String   // Justification de la suggestion
  status        String   @default("pending") // "pending" | "approved" | "rejected" | "auto_applied"
  
  approvedAt    DateTime?
  rejectedAt    DateTime?
  appliedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([legalUpdateId])
  @@index([status])
}

model GovernmentMember {
  id        String   @id @default(cuid())
  name      String
  role      String   // "Président" | "Premier ministre" | "Ministre" | etc.
  ministry  String?  // Ministère ou portefeuille
  active    Boolean  @default(true)
  source    String?  // Source de l'information
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model VeilleLog {
  id          String   @id @default(cuid())
  action      String   // "search" | "analyze" | "apply" | "government_update"
  status      String   // "started" | "completed" | "error"
  details     String?  // Détails ou message d'erreur
  resultsCount Int     @default(0)
  duration    Int      @default(0)  // Durée en ms
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

model VeilleConfig {
  id                String   @id @default(cuid())
  key               String   @unique
  value             String
  description       String?
  lastCheckedAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
