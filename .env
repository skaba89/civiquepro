# Base de données
DATABASE_URL=file:/home/z/my-project/db/custom.db

# NextAuth
NEXTAUTH_SECRET=civiquepro-dev-secret-key-2026-super-secure
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
# 1. Allez sur https://console.cloud.google.com/
# 2. Créez un projet ou sélectionnez un projet existant
# 3. Activez l'API Google+
# 4. Créez des identifiants OAuth 2.0 (Type: Application Web)
# 5. Ajoutez http://localhost:3000/api/auth/callback/google aux URI de redirection autorisés
# 6. Copiez l'ID client et le secret ci-dessous
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
# 1. Allez sur https://developers.facebook.com/
# 2. Créez une application (Type: Consommateur)
# 3. Ajoutez le produit "Connexion Facebook"
# 4. Dans Paramètres > OAuth, ajoutez http://localhost:3000/api/auth/callback/facebook aux URI de redirection valides
# 5. Copiez l'ID de l'application et la clé secrète ci-dessous
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
