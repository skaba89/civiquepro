# ━━ CiviquePro - Environment Variables ━━

# Database — PostgreSQL (Neon or local)
# For local dev with SQLite, comment the PostgreSQL URL and uncomment the SQLite line
DATABASE_URL=file:/home/z/my-project/db/custom.db
# DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-XXXX-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require

# Authentication (required)
NEXTAUTH_SECRET=dev-only-secret-change-in-production-civiquepro-2026
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional - mock mode used if not set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
